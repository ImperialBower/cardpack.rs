# fr/skat.ftl — French (français) translation
#
# Status: DRAFT — LOW CONFIDENCE. Needs review by a French Skat player before merge.
# Skat is a German game; French Skat terminology is not universally fixed.
#
# Specific concerns:
#   - "Daus" (rank-d) is the HIGH trump in Skat. Etymologically "deuce" but
#     functionally an Ace. A literal translation to "Deux" would be SEMANTICALLY
#     WRONG. Translated here as "As".
#   - Ober/Unter (rank-o, rank-u) are sometimes kept as German loanwords in
#     French Skat circles. Translated here as Dame/Valet for accessibility.
#   - Suit names follow the German originals translated as nouns (Glands,
#     Feuilles, Cœur, Grelots). pagat.com is the canonical cross-reference:
#     https://www.pagat.com/schafkopf/skat.html

name-suit-skat-e = Glands
name-suit-skat-l = Feuilles
name-suit-skat-h = Cœur
name-suit-skat-s = Grelots
name-suit-skat-_ = Vide

name-rank-skat-d = As
name-rank-skat-z = Dix
name-rank-skat-k = Roi
name-rank-skat-o = Dame
name-rank-skat-u = Valet
name-rank-skat-9 = Neuf
name-rank-skat-8 = Huit
name-rank-skat-7 = Sept
