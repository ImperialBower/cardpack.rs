# la/skat.ftl — Latin (Latina) translation
#
# Status: DRAFT — LOW-MEDIUM CONFIDENCE. Skat is a German game and there is
# no historical Latin Skat tradition. Suit names are direct semantic
# translations of the German originals (Eichel/Laub/Herz/Schellen ->
# Glandes/Folia/Corda/Tintinnabula). Court ranks use Superior/Inferior for
# Ober/Unter — direct semantic translation of the German positional terms
# ("upper"/"lower"), more precise than mapping to Regina/Famulus.
#
# Specific concerns:
#   - rank-d ("Daus") is the HIGH trump in Skat. Etymologically "deuce" but
#     functionally an Ace. A literal "Duo" would be SEMANTICALLY WRONG.
#     Translated here as "As" (matches en-US/fr conventions and Skat
#     semantics).
#   - Ober/Unter are translated as Superior/Inferior. A Latinist may prefer
#     classical court titles (Magister/Famulus) or German loanwords; the
#     positional semantics chosen here align with the actual game function.
#
# Needs: Latinist with Skat awareness, or pagat.com cross-reference, before
# promotion. https://www.pagat.com/schafkopf/skat.html

name-suit-skat-e = Glandes
name-suit-skat-l = Folia
name-suit-skat-h = Corda
name-suit-skat-s = Tintinnabula
name-suit-skat-_ = Vacuum

name-rank-skat-d = As
name-rank-skat-z = Decem
name-rank-skat-k = Rex
name-rank-skat-o = Superior
name-rank-skat-u = Inferior
