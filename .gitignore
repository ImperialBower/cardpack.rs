# Generated by Cargo
# will have compiled files and executables
/target/

# Cargo.lock is committed (current Rust guidance, even for libraries) so CI is
# deterministic — the 1.85 MSRV gate broke when a fresh resolve picked up
# ignore 0.4.30, which needs rustc 1.88 but declares no rust-version.
# https://blog.rust-lang.org/2023/08/29/committing-lockfiles/

# These are backup files generated by rustfmt
**/*.rs.bk

# Stray build artifacts (e.g., from running rustc/cargo invocations outside target/)
*.rlib
*.rmeta


#Added by cargo
#
#already existing elements were commented out

/target
#Cargo.lock
mutants.out/
mutants.out.*/
.claude/
